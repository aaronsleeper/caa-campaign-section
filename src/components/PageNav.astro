---
interface Props {
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="page-nav" aria-label="Page navigation">
    {prev ? (
      <a href={prev.href} class="page-nav__link page-nav__link--prev">
        <span class="page-nav__kicker">&larr; Back to</span>
        <span class="page-nav__label">{prev.label}</span>
      </a>
    ) : <span />}
    {next && (
      <a href={next.href} class="page-nav__link page-nav__link--next">
        <span class="page-nav__kicker">Up next &rarr;</span>
        <span class="page-nav__label">{next.label}</span>
      </a>
    )}
  </nav>
)}
