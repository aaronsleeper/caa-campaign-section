---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Top section-nav strip. Reimbursement sub-pages (3a/3b/3c) are parallel cards
// on the gateway, not strip items (no implied sequence). The overview-video
// page exists at /overview-video/ as an unlinked direct-link destination
// (Option 2, confirmed by CAA 2026-05-29) — it intentionally does not appear
// in the nav.
const navItems = [
  { href: `${base}/`, label: 'SB 54 Home' },
  { href: `${base}/whats-changing/`, label: "What's Changing" },
  { href: `${base}/roles-and-responsibilities/`, label: 'Roles' },
  { href: `${base}/reimbursement/`, label: 'Reimbursement' },
];

// A reimbursement sub-page should highlight the Reimbursement parent.
const isCurrent = (href: string) =>
  currentPath === href ||
  (href.endsWith('/reimbursement/') && currentPath.includes('/reimbursement/'));
---

<nav class="section-nav" aria-label="In this section">
  <div class="section-nav__inner">
    <ul class="section-nav__list">
      {navItems.map((item) => (
        <li class:list={['section-nav__item', { 'section-nav__item--current': isCurrent(item.href) }]}>
          <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .section-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--caa-paper);
    border-bottom: 1px solid color-mix(in srgb, var(--caa-navy) 12%, transparent);
  }

  .section-nav__inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .section-nav__list {
    display: flex;
    gap: var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .section-nav__item a {
    display: block;
    padding: var(--space-md) 0;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--caa-navy);
    text-decoration: none;
    border-bottom: 3px solid transparent;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }

  .section-nav__item a:hover {
    color: var(--caa-teal);
  }

  .section-nav__item--current a {
    color: var(--caa-teal);
    border-bottom-color: var(--caa-teal);
  }

  @media (max-width: 768px) {
    .section-nav__list {
      gap: var(--space-md);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>
