---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionNav from '../components/SectionNav.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="SB 54 in California" description="California's producer-funded packaging law. Learn what SB 54 is, who it affects, how roles and reimbursement work, and how CAA supports the system.">
  <SectionNav currentPath={`${base}/`} />
  <div class="page">
    <!-- Hero: heading + lead-in sit above the rectangle; the navy rectangle IS the
         video, offset against the gold + teal mats (the live /california layered-panel
         device). No video file yet, so it renders as a 'Coming soon' placeholder. -->
    <div class="hero-intro">
      <h1><em>SB&nbsp;54</em> in California</h1>
      <p class="hero-intro__lead">
        California is taking on one of its most ambitious recycling and packaging challenges yet. SB&nbsp;54 is one of the most comprehensive and far-reaching packaging responsibility laws in the U.S., creating a producer-funded system to support recycling, composting, and waste management improvements across the state.
      </p>
    </div>

    <div class="hero--blocked hero--blocked--video">
      <figure class="video-placeholder video-placeholder--image hero-video" aria-label="Video coming">
        <img src={`${base}/fpo/2.png`} alt="Sorted recyclable materials presented as valuable commodities on a teal ground — video coming." class="video-placeholder__image" />
        <div class="video-placeholder__overlay">
          <div class="video-placeholder__mark" aria-hidden="true">
            <div class="video-placeholder__spark"></div>
            <span class="video-placeholder__play">&#9654;</span>
          </div>
          <span class="video-placeholder__label">Video coming</span>
        </div>
      </figure>
    </div>

    <h2 class="hub__heading">Start with the topic that's most relevant to where you are right now</h2>
    <div class="card-grid">
      <div class="card">
        <span class="card__number">1</span>
        <h3 class="card__title">What SB 54 Means for You</h3>
        <p class="card__description">
          Learn what is changing under SB 54, what stays the same, and what to expect as implementation moves forward.
        </p>
        <a href={`${base}/whats-changing/`} class="card__cta sqs-block-button-element sqs-block-button-element--medium sqs-button-element--primary">Start here &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">2</span>
        <h3 class="card__title">Roles and Responsibilities</h3>
        <p class="card__description">
          Understand who does what under SB 54, how responsibilities are shared, and where your organization fits.
        </p>
        <a href={`${base}/roles-and-responsibilities/`} class="card__cta sqs-block-button-element sqs-block-button-element--medium sqs-button-element--primary">Find your role &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">3</span>
        <h3 class="card__title">Reimbursement for Covered Costs <span class="card__tag">(Coming Soon)</span></h3>
        <p class="card__description">
          Learn how reimbursement works, what costs may be eligible, and how to prepare for future funding opportunities.
        </p>
        <a href={`${base}/reimbursement/`} class="card__cta sqs-block-button-element sqs-block-button-element--medium sqs-button-element--primary">Reimbursement overview &rarr;</a>
      </div>
    </div>

    <!-- Goals of SB 54 — reproduces the live CAA "Key Goals" grid -->
    <div class="band band--tint-teal">
      <p class="band__title">Goals of SB 54</p>
      <p class="band__eyebrow">By January 1, 2032:</p>
      <div class="checks">
        <div class="stat">
          <div class="stat__head">
            <img class="stat__icon" src={`${base}/icons/bottle.svg`} alt="" aria-hidden="true" />
            <span class="stat__figure">25%</span>
          </div>
          <span class="stat__label">reduction in single-use plastic packaging</span>
        </div>
        <div class="stat">
          <div class="stat__head">
            <img class="stat__icon" src={`${base}/icons/recycle.svg`} alt="" aria-hidden="true" />
            <span class="stat__figure">65%</span>
          </div>
          <span class="stat__label">recycling rate</span>
        </div>
        <div class="stat">
          <div class="stat__head">
            <img class="stat__icon" src={`${base}/icons/compostibles.svg`} alt="" aria-hidden="true" />
            <span class="stat__figure">100%</span>
          </div>
          <span class="stat__label">of packaging recyclable or compostable</span>
        </div>
      </div>
    </div>

    <!-- Split: who this is for, beside a brand graphic -->
    <div class="split split--media-right">
      <div class="split__media media-frame">
        <figure class="fpo fpo--filled fpo--framed">
          <img src={`${base}/fpo/3.png`} alt="Recycling-system operators — coordinator, hauler, MRF worker — together on-site." />
          <span class="fpo__pov-flag" aria-label="Tier 3 RED per AI Imagery POV — replace with commissioned community photography">Tier 3 · Commission</span>
        </figure>
      </div>
      <div class="split__body">
        <p class="hub__subtitle">
          Whether you're already involved in this work or just beginning to learn about SB 54, this site is here to help you understand what is changing, where you fit, and how to access available support and funding.
        </p>
      </div>
    </div>

    <!-- Closing engagement block. Approved CTA wording from CAA Comms (Dana, 2026-05-27).
         Primary action: the inquiry form (same participation form used across the modules). -->
    <div class="hub__cta">
      <p class="hub__cta-lead">If you haven't connected with CAA yet, complete the CAA California Recycling &amp; Reuse System Inquiry Form. Knowing a bit more about your organization helps CAA point you to the best next steps.</p>
      <a href="https://www.surveymonkey.com/r/2M3GMYV" class="cta-button" target="_blank" rel="noopener">Complete the inquiry form&nbsp;&rarr;</a>
      <p class="hub__cta-secondary">You can also <a href="https://circularactionalliance.org/newsletter-subscription" class="hub__cta-newsletter" target="_blank" rel="noopener">sign up to receive CAA updates via our newsletter</a>.</p>
    </div>
  </div>
</BaseLayout>

<style>
  /* Hero composition lives in global.css (.hero--blocked et al.) so module
     pages can reuse it. This block holds hub-specific bits only. */
  .hub__subtitle {
    font-size: var(--text-lg);
    color: var(--caa-navy);
    max-width: var(--max-line-length);
    opacity: 0.85;
  }

  .hub__heading {
    margin-top: var(--space-2xl);
  }

  .card__tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--caa-teal-dark, var(--caa-teal));
    opacity: 0.85;
    margin-left: var(--space-xs);
    letter-spacing: 0.02em;
  }

  .card__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--caa-teal);
    color: var(--caa-paper);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .hub__cta {
    padding-top: var(--space-2xl);
    max-width: var(--max-line-length);
  }
  .hub__cta-lead {
    font-size: var(--text-base);
    color: var(--caa-navy);
  }
  .hub__cta-secondary {
    font-size: var(--text-sm);
    color: var(--caa-navy);
    margin-top: var(--space-md);
  }
  /* Full-strength accessible teal link (the container's old opacity:0.7 washed it out). */
  .hub__cta-secondary a {
    color: var(--caa-teal-dark);
    font-weight: 600;
  }
</style>
