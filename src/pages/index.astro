---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionNav from '../components/SectionNav.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="SB 54 in California" description="SB 54 interest-holder education materials — understand the law, your role, and how to access reimbursement.">
  <SectionNav currentPath={`${base}/`} />
  <div class="page">
    <div class="hero">
      <h1>SB 54 in California</h1>
      <p class="hub__subtitle">
        California is taking on one of its most ambitious recycling and packaging challenges yet. SB 54 is a groundbreaking law that shifts responsibility for funding the recycling system to the companies that make and sell packaging, and sets bold goals for what that system can achieve.
      </p>
    </div>

    <!-- Stat band — reproduces the live CAA "Key Goals" grid -->
    <div class="band band--tint-teal">
      <p class="band__eyebrow">By January 1, 2032, SB 54 aims to:</p>
      <div class="stat-row">
        <div class="stat">
          <span class="stat__number">25%</span>
          <span class="stat__label">reduction in single-use plastic packaging</span>
        </div>
        <div class="stat">
          <span class="stat__number">65%</span>
          <span class="stat__label">recycling rate</span>
        </div>
        <div class="stat">
          <span class="stat__number">100%</span>
          <span class="stat__label">of packaging recyclable or compostable</span>
        </div>
      </div>
    </div>

    <!-- Split: who this is for, beside a brand graphic -->
    <div class="split split--media-right">
      <figure class="split__media fpo">
        <span class="fpo__tag">Image &middot; FPO</span>
        <span class="fpo__desc">Abstract Circular Motion: layered, semi-transparent Unity Spark arcs in teal and navy &mdash; a system coming together. No literal objects; the brand signature as the cover image.</span>
      </figure>
      <div class="split__body">
        <p class="hub__subtitle">
          The people who will make that happen are already out there doing this work. If that includes you, this site is here to help you understand what is changing, where you fit, and how to access the support and funding that comes with it.
        </p>
      </div>
    </div>

    <div class="video-placeholder">
      <div class="video-placeholder__inner">
        <span class="video-placeholder__icon" aria-hidden="true">&#9654;</span>
        <span class="video-placeholder__label">Overview video &mdash; coming soon</span>
      </div>
    </div>

    <h2 class="hub__heading">Start with the part that fits you</h2>
    <div class="card-grid">
      <div class="card">
        <span class="card__number">1</span>
        <h3 class="card__title">What SB 54 Means for You</h3>
        <p class="card__description">
          Understand what is changing, what is not, and why it matters for your organization.
        </p>
        <a href={`${base}/whats-changing/`} class="card__cta">Start here &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">2</span>
        <h3 class="card__title">Roles and Responsibilities</h3>
        <p class="card__description">
          See how your work connects to the bigger picture and where you fit in the new system.
        </p>
        <a href={`${base}/roles-and-responsibilities/`} class="card__cta">Find your role &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">3</span>
        <h3 class="card__title">Reimbursement for Covered Costs</h3>
        <p class="card__description">
          Producer funding is flowing back into the system. Find out what is eligible and how to prepare.
        </p>
        <a href={`${base}/reimbursement/`} class="card__cta">See reimbursement &rarr;</a>
      </div>
    </div>

    <div class="hub__links">
      <a href="mailto:internalcomms@circularaction.org">Contact CAA Communications</a>
    </div>
  </div>
</BaseLayout>

<style>
  .hub__subtitle {
    font-size: var(--text-lg);
    color: var(--caa-navy);
    max-width: var(--max-line-length);
    opacity: 0.85;
  }

  .hub__heading {
    margin-top: var(--space-2xl);
  }

  .card__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--caa-teal);
    color: var(--caa-paper);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .hub__links {
    padding-top: var(--space-2xl);
    font-size: var(--text-sm);
    color: var(--caa-ink);
    opacity: 0.7;
  }
</style>
