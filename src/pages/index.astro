---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="SB 54 in California" description="SB 54 interest-holder education materials — understand the law, your role, and how to access reimbursement.">
  <div class="hub">
    <div class="hub__hero">
      <h1>SB 54 in California</h1>
      <p class="hub__subtitle">
        California's recycling and packaging system is changing. These materials help you understand what SB 54 requires, where you fit, and how to access reimbursement for covered costs.
      </p>
    </div>

    <div class="card-grid">
      <div class="card">
        <span class="card__number">1</span>
        <h2 class="card__title">What SB 54 Means for You</h2>
        <p class="card__description">
          What the law requires, who it affects, and what changes before 2027.
        </p>
        <a href={`${base}/whats-changing/`} class="card__cta">Start here &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">2</span>
        <h2 class="card__title">Roles and Responsibilities</h2>
        <p class="card__description">
          Every organization in California's recycling system has a defined role under SB 54. Find yours.
        </p>
        <a href={`${base}/roles-and-responsibilities/`} class="card__cta">Find your role &rarr;</a>
      </div>

      <div class="card">
        <span class="card__number">3</span>
        <h2 class="card__title">Reimbursement for Covered Costs</h2>
        <p class="card__description">
          SB 54 reimburses the work of collecting and processing California's recyclable commodities.
        </p>
        <a href={`${base}/reimbursement/`} class="card__cta">See reimbursement &rarr;</a>
      </div>
    </div>

    <div class="hub__links">
      <a href={`${base}/questions/`}>Questions</a> &middot;
      <a href="mailto:internalcomms@circularaction.org">Contact CAA Communications</a>
    </div>
  </div>
</BaseLayout>

<style>
  .hub {
    max-width: calc(var(--content-width) + var(--sidebar-width) + var(--space-2xl));
    margin: 0 auto;
    padding: var(--space-xl);
  }

  .hub__hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    border-bottom: 3px solid var(--caa-teal);
    margin-bottom: var(--space-2xl);
  }

  .hub__subtitle {
    font-size: var(--text-lg);
    color: var(--caa-navy);
    max-width: var(--max-line-length);
    opacity: 0.85;
  }

  .card__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--caa-teal);
    color: var(--caa-paper);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .hub__links {
    padding-top: var(--space-xl);
    font-size: var(--text-sm);
    color: var(--caa-ink);
    opacity: 0.7;
  }
</style>
