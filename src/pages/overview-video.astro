---
import ModuleLayout from '../layouts/ModuleLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Dedicated overview-video page (Option B). A single-purpose destination for the
     June interest-holder push: one shareable URL (/overview-video/), the video,
     and one engagement action (the inquiry form). Keeps the hub hero reserved for
     the eventual animated piece. Recommended by the Demand-Gen / Content Design /
     CAA Visual lenses (2026-05-27). -->
<ModuleLayout
  title="Watch the SB 54 Overview"
  titleHtml={`Watch the <em>SB&nbsp;54</em> Overview`}
  currentPath={`${base}/overview-video/`}
>
  <section class="section section--intro">
    <p>A few minutes on what SB 54 means for California&rsquo;s recycling system: what is changing, who it affects, and the funding and support now available to the organizations doing the work. When you are ready, tell us how you fit in and CAA will point you to the right next steps.</p>
  </section>

  <figure class="video-placeholder video-placeholder--image video-placeholder--wide" aria-label="Video coming">
    <img src={`${base}/fpo/3.png`} alt="Recycling-system operators — coordinator, hauler, MRF worker — together on-site — video coming." class="video-placeholder__image" />
    <div class="video-placeholder__overlay">
      <div class="video-placeholder__mark" aria-hidden="true">
        <div class="video-placeholder__spark"></div>
        <span class="video-placeholder__play">&#9654;</span>
      </div>
      <span class="video-placeholder__label">Video coming</span>
    </div>
  </figure>

  <!-- CTA band — the page's single Action Yellow lives here. One engagement
       action: the SB 54 interest-holder inquiry form. -->
  <div class="band band--tint-teal">
    <section class="cta-block cta-block--single">
      <h2>Get connected with CAA</h2>
      <p>If you haven&rsquo;t connected with CAA yet, complete the CAA California Recycling &amp; Reuse System Inquiry Form. Knowing a bit more about your organization helps CAA point you to the best next steps.</p>
      <a href="https://www.surveymonkey.com/r/2M3GMYV" class="cta-button" target="_blank" rel="noopener">Complete the inquiry form&nbsp;&rarr;</a>
    </section>
  </div>
</ModuleLayout>
