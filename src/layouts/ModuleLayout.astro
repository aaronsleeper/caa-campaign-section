---
import BaseLayout from './BaseLayout.astro';
import SectionNav from '../components/SectionNav.astro';
import PageNav from '../components/PageNav.astro';

interface Props {
  title: string;
  /* Optional HTML for the visible hero heading. Use to apply the site-native
     highlight, e.g. titleHtml={`What <em>SB&nbsp;54</em> Means for You`} renders
     a teal underline bar on "SB 54" (inherits the live `h1 em` rule in
     Squarespace; the global.css fallback replicates it standalone). The plain
     `title` string is still used for the <title> tag and as the fallback. */
  titleHtml?: string;
  subtitle?: string;
  description?: string;
  currentPath: string;
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}

const { title, titleHtml, subtitle, description, currentPath, prev, next } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <SectionNav currentPath={currentPath} />
  <div class="page">
    <div class="hero">
      {titleHtml ? <h1 set:html={titleHtml} /> : <h1>{title}</h1>}
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    </div>
    <slot />
    <PageNav prev={prev} next={next} />
  </div>
</BaseLayout>
