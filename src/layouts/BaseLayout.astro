---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE_ORIGIN = 'https://aaronsleeper.github.io';
const DEFAULT_OG_IMAGE = `${SITE_ORIGIN}${base}/fpo/3.png`;
const resolvedOgImage = ogImage || DEFAULT_OG_IMAGE;
const pageUrl = `${SITE_ORIGIN}${Astro.url.pathname}`;
const fullTitle = `${title} — Circular Action Alliance`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Circular Action Alliance" />
  <meta property="og:title" content={fullTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={resolvedOgImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,200;9..40,300;9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet" />

  <!--
    LIVE CAA SITE STYLES — direct-linked from circularactionalliance.org's CDN.

    Loading these in this <head> makes the standalone preview render with the
    same Squarespace stylesheet bundle the production site uses, so reviewers
    see the section as it will look once Larine builds the pages natively
    (per SQUARESPACE-BUILD-SPEC.md). Our own global.css layers on top below
    and adds rules for the custom components Squarespace doesn't have a
    native pattern for (numbered step cards, stats callout, layout grids).

    URLs were extracted from view-source:circularactionalliance.org on
    2026-06-02. They are versioned/hashed by Squarespace and stable until
    CAA pushes a Site Styles change; if the preview starts looking wrong,
    re-extract from the live <head>.

    Load order matters: live styles first (baseline tokens + type + custom
    accents), then our global.css (overrides where needed, plus components
    that don't exist live). custom.css uses !important on h1 em / h3 strong
    so it pins those treatments regardless of cascade order.
  -->
  <link rel="stylesheet" href="https://static1.squarespace.com/static/versioned-site-css/64260ed078c36925b1cf3385/252/5c5a519771c10ba3470d8101/64260ed178c36925b1cf339f/1789/site.css?nocustom=true" />
  <link rel="stylesheet" href="https://static1.squarespace.com/static/vta/5c5a519771c10ba3470d8101/versioned-assets/1780419127951-K5FIIEY2NNREJWC8JB19/static.css" />
  <link rel="stylesheet" href="https://static1.squarespace.com/static/custom-css/64260ed078c36925b1cf3385/64260ed178c36925b1cf339f/1/custom.css" />
</head>
<body>
  <!-- CONTEXT ONLY: a faithful representation of CAA's existing site header,
       to show how the campaign section sits within their site. Not a deliverable. -->
  <header class="site-header" aria-label="Existing CAA site header (shown for context)">
    <div class="site-header__inner">
      <a href="https://circularactionalliance.org/" class="site-header__logo" target="_blank" rel="noopener">
        <svg class="site-header__spark" viewBox="0 0 40 40" aria-hidden="true">
          <circle cx="20" cy="20" r="13" fill="none" stroke="#196D80" stroke-width="5" stroke-dasharray="2.5 4.5" stroke-linecap="round" />
        </svg>
        <span class="site-header__wordmark">Circular<br />Action<br />Alliance</span>
      </a>
      <nav class="site-header__nav" aria-label="CAA site navigation (context)">
        <a href="https://circularactionalliance.org/about" target="_blank" rel="noopener">About</a>
        <a href="https://circularactionalliance.org/california" target="_blank" rel="noopener">States</a>
        <a href="https://circularactionalliance.org/news" target="_blank" rel="noopener">News &amp; Events</a>
        <a href="https://circularactionalliance.org/resources" target="_blank" rel="noopener">Producers</a>
      </nav>
      <div class="site-header__right">
        <span class="site-header__social" aria-hidden="true">in&nbsp;&nbsp;&#120143;&nbsp;&nbsp;&#9654;</span>
        <a class="site-header__pill" href="https://circularactionalliance.org/registration" target="_blank" rel="noopener">Producer Registration</a>
      </div>
    </div>
  </header>

  <div class="context-note">
    <p><strong>Prototype context:</strong> the bar above is CAA&rsquo;s <em>existing</em> site header, shown only to illustrate placement &mdash; it is not part of this deliverable. Everything below is the new SB&nbsp;54 campaign section we designed to live within your site, beginning with its section navigation.</p>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <!-- Internal-comms mailto removed 2026-05-27 (Dana: incorrect/internal address, sitewide).
           Public footer contact link pending a correct address from CAA Comms. -->
      <p>&copy; Circular Action Alliance</p>
      <p class="site-footer__note">This is a preview prototype. Content is subject to CAA review and approval.</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    background: var(--caa-paper);
    border-bottom: 1px solid color-mix(in srgb, var(--caa-navy) 10%, transparent);
    padding: var(--space-md) var(--space-xl);
  }

  .site-header__inner {
    max-width: calc(var(--content-width) + var(--sidebar-width) + var(--space-2xl));
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .site-header__logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .site-header__spark {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .site-header__wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-base);
    line-height: 1.02;
    color: var(--caa-navy);
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-lg);
  }

  .site-header__nav a {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--caa-navy);
    text-decoration: none;
  }

  .site-header__right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .site-header__social {
    color: var(--caa-navy);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
  }

  .site-header__pill {
    background: var(--caa-yellow);
    color: var(--caa-navy);
    border-radius: 999px;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-display);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }

  /* Prototype context note — deliberately meta scaffolding, not part of the design */
  .context-note {
    background: color-mix(in srgb, var(--caa-navy) 4%, var(--caa-paper));
    border-bottom: 1px dashed color-mix(in srgb, var(--caa-navy) 30%, transparent);
    padding: var(--space-sm) var(--space-xl);
  }

  .context-note p {
    max-width: calc(var(--content-width) + var(--sidebar-width) + var(--space-2xl));
    margin: 0 auto;
    font-size: var(--text-xs);
    font-style: italic;
    color: color-mix(in srgb, var(--caa-navy) 70%, transparent);
  }

  .site-footer {
    background: var(--caa-navy);
    color: rgba(255, 255, 255, 0.7);
    padding: var(--space-xl);
    margin-top: var(--space-3xl);
    font-size: var(--text-sm);
  }

  .site-footer__inner {
    max-width: calc(var(--content-width) + var(--sidebar-width) + var(--space-2xl));
    margin: 0 auto;
  }

  /* Gold underlined links — matches the live site's footer link treatment
     (aqua read too bright on the navy footer). */
  .site-footer a {
    color: var(--caa-yellow);
  }

  .site-footer__note {
    opacity: 0.5;
    font-size: var(--text-xs);
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .site-header {
      padding: var(--space-sm) var(--space-md);
    }

    .site-header__nav,
    .site-header__social {
      display: none;
    }
  }
</style>
